<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="BRDP" value="https://nexus3.dotin.ir/repository/brdp-nuget/" />
    <add key="nuget.org-proxy" value="https://nexus3.dotin.ir/repository/nuget.org-proxy/" />
    <add key="Baget" value="http://10.100.8.64/v3/index.json" allowInsecureConnections="true" />
    <!-- Private Gemfury feed (restore). Token comes from the GEMFURY_DEPLOY_TOKEN env var
         so it is never committed. See push instructions in the comment below. -->
    <add key="gemfury" value="https://nuget.fury.io/agaheman/" />
  </packageSources>

  <packageSourceCredentials>
    <BRDP>
      <add key="Username" value="brdp-view" />
      <add key="ClearTextPassword" value="brdp4view" />
    </BRDP>
    <gemfury>
      <add key="Username" value="agaheman" />
      <!-- NuGet expands %ENV% at runtime; set GEMFURY_DEPLOY_TOKEN in your environment. -->
      <add key="ClearTextPassword" value="%GEMFURY_DEPLOY_TOKEN%" />
    </gemfury>
  </packageSourceCredentials>

  <!--
    Publish (push) a package to Gemfury — the push token is NOT stored here.
    Set GEMFURY_PUSH_TOKEN in your environment, then:

      dotnet pack -c Release
      # NuGet push:
      dotnet nuget push bin/Release/*.nupkg -s https://push.fury.io/agaheman/ -k %GEMFURY_PUSH_TOKEN%
      # or the curl form Gemfury documents:
      curl -F package=@bin/Release/YourPackage.1.0.0.nupkg https://%GEMFURY_PUSH_TOKEN%@push.fury.io/agaheman/
  -->
</configuration>
